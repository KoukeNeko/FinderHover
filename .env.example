# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Your Apple ID email
APPLE_ID=XXXXXXXXX@XXX

# Your 10-character Apple Team ID
APPLE_TEAM_ID=XXXXXXXX

# App-Specific Password from https://appleid.apple.com
# (NOT your regular Apple ID password)
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Exact codesign identity — run `security find-identity -v -p codesigning` to confirm
SIGN_IDENTITY=Developer ID Application: Your Name (XXXXXXXXXX)
